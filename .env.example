# Supabase API URL, e.g. http://localhost:54321 for local dev or your hosted project URL
VITE_SUPABASE_URL=https://your-project.supabase.co
# Preferred browser key for hosted projects
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Public anon key fallback for local dev or older setups
VITE_SUPABASE_ANON_KEY=your-anon-key
